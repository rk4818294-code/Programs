#include<iostream>
using namespace std;
int main(){ 
    int x=12;                                                             // bitwise = & , |
    int y=23;                                                          
    int z1= x&y;
    int z2= x|y;
    cout<< " z1 : "<< z1<< endl;
    cout<< " z2 : "<< z2<< endl;
    return 0 ;
}

